---
import Layout from "../../layouts/Layout.astro";
import ProjectTemplate from "../../components/ProjectTemplate.astro";
---

<Layout>
  <ProjectTemplate
    title="Quarto Infantil"
    category="Quarto"
    location="São José"
    year={2026}
    heroImage="/images/projects/quarto-infantil-03.jpg"
    challenge={[
      "Os projetos de quartos infantis são desenvolvidos para unir conforto, funcionalidade e criatividade.",
      "A composição de cores, mobiliário e elementos decorativos é cuidadosamente planejada para estimular o bem-estar, a imaginação e a autonomia.",
      "✨👶🧸 Projetos personalizados para meninos, meninas, irmãos e gêmeos.",
    ]}
    solution="Foi desenvolvida uma marcenaria sob medida, utilizando tons claros e iluminação indireta para ampliar visualmente o espaço."
    gallery={[
      "/images/projects/quarto-infantil-01.jpg",
      "/images/projects/quarto-infantil-02.jpg",
      "/images/projects/quarto-infantil-03.jpg",
      "/images/projects/quarto-infantil-04.jpg",
      "/images/projects/quarto-infantil-05.jpg",
    ]}
  />
</Layout>
