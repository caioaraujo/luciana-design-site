---
import Layout from "../../layouts/Layout.astro";
import ProjectTemplate from "../../components/ProjectTemplate.astro";
---

<Layout>
    <ProjectTemplate
        title="Espaços comerciais"
        category="Loja"
        location="São José"
        year={2026}
        heroImage="/images/projects/loja-04.jpg"
        challenge={[
            "Desenvolvemos projetos comerciais que unem identidade visual, funcionalidade e experiência do cliente, criando ambientes estratégicos, acolhedores e visualmente marcantes. Cada espaço é planejado para valorizar a marca, otimizar a operação e proporcionar conforto aos usuários, combinando estética, iluminação, materiais e layout de forma harmoniosa.",
            "✨ Soluções personalizadas para transformar ambientes comerciais em espaços modernos, funcionais e alinhados aos objetivos de cada negócio.",
        ]}
        solution="Foi desenvolvida uma marcenaria sob medida, utilizando tons claros e iluminação indireta para ampliar visualmente o espaço."
        gallery={[
            "/images/projects/loja-01.jpg",
            "/images/projects/loja-02.jpg",
            "/images/projects/loja-03.jpg",
            "/images/projects/loja-04.jpg",
            "/images/projects/loja-05.jpg",
        ]}
    />
</Layout>
