---
import Layout from "../../layouts/Layout.astro";
import ProjectTemplate from "../../components/ProjectTemplate.astro";
---

<Layout>
    <ProjectTemplate
        title="Closet"
        category="Closet"
        location="São José"
        year={2026}
        heroImage="/images/projects/closet-01.jpg"
        challenge={[
            "Projetado para unir sofisticação, organização e conforto, este closet de alto padrão valoriza a experiência diária através de uma composição elegante de tons neutros, iluminação planejada e materiais nobres. A entrada de luz natural por meio da janela superior amplia a sensação de bem-estar, enquanto os espelhos proporcionam amplitude e refinamento ao ambiente.",
            "O resultado é um espaço funcional, acolhedor e atemporal, pensado para transformar a rotina em uma experiência de exclusividade e praticidade. ✨🤍",
        ]}
        solution="Foi desenvolvida uma marcenaria sob medida, utilizando tons claros e iluminação indireta para ampliar visualmente o espaço."
        gallery={[
            "/images/projects/closet-01.jpg",
            "/images/projects/closet-02.jpg",
            "/images/projects/closet-03.jpg"
        ]}
    />
</Layout>
