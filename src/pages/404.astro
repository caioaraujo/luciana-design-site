---
import Layout from "../layouts/Layout.astro";

const whatsappMessage = encodeURIComponent(
  "Olá, Luciana! Encontrei uma página inexistente no site, mas gostaria de conversar sobre um projeto."
);
---

<Layout>

  <section
    class="min-h-screen flex items-center justify-center bg-stone-950 text-white px-6"
  >
    <div class="max-w-2xl text-center">

      <span
        class="uppercase tracking-[0.4em] text-sm text-[#d4b190]"
      >
        Nova Art Design
      </span>

      <h1
        class="mt-6 text-7xl md:text-8xl font-light text-[#d4b190]"
      >
        404
      </h1>

      <h2
        class="mt-4 text-3xl md:text-4xl font-light text-[#d4b190]"
      >
        Este ambiente ainda não foi projetado.
      </h2>

      <p
        class="mt-6 text-stone-300 leading-relaxed"
      >
        O conteúdo que você procura não existe ou foi movido.
        Aproveite para conhecer alguns dos projetos da Nova Art Design.
      </p>

      <div
        class="mt-10 flex flex-col sm:flex-row gap-4 justify-center"
      >
        <a
          href="/"
          class="px-8 py-4 bg-[#d4b190] text-stone-900 rounded-md font-medium hover:opacity-90 transition"
        >
          Voltar para Home
        </a>

        <a
          href={`https://wa.me/5548984043490?text=${whatsappMessage}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 border border-white rounded-md hover:bg-white/10 transition"
        >
          Falar com a Luciana
        </a>
      </div>

    </div>
  </section>

</Layout>