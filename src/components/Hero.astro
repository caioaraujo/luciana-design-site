---
interface Props {
  image: string;
}

const { image } = Astro.props;

const whatsappMessage = encodeURIComponent(
  "Olá, Luciana! Visitei o site da Nova Arte Design e gostaria de conversar sobre um projeto de interiores.",
);
---

<section class="relative min-h-screen">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src={image}
      alt="Projeto de interiores"
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 min-h-screen flex items-center">
    <div class="max-w-7xl mx-auto px-6 w-full text-white">
      <!-- Logo -->
      <img
        src="/images/logo/logo.jpg"
        alt="Nova Arte Design"
        class="w-48 md:w-64 lg:w-80 mb-10"
      />

      <!-- Headline -->
      <span class="uppercase tracking-[0.3em] text-sm text-stone-200">
        Design de Interiores
      </span>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-light leading-tight">
        Transformando ambientes em
        <span class="italic"> experiências únicas </span>
      </h1>

      <p class="mt-8 text-lg text-stone-200 leading-relaxed">
        Projetos de interiores personalizados que unem beleza, funcionalidade e
        conforto.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href={`https://wa.me/5548984043490?text=${whatsappMessage}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-[#d4b190] text-stone-900 rounded-md font-medium hover:opacity-90 transition"
        >
          Solicitar Orçamento
        </a>

        <a
          href="#projetos"
          class="px-8 py-4 border border-white rounded-md hover:bg-white/10 transition"
        >
          Ver Projetos
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <a
    href="#projetos"
    class="hidden md:block absolute z-30 bottom-8 left-1/2 -translate-x-1/2 text-white animate-bounce"
    aria-label="Ir para projetos"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
    </svg>
  </a>
</section>
