---
interface Props {
  image: string;
}

const { image } = Astro.props;

const whatsappMessage = encodeURIComponent(
  "Olá, Luciana! Visitei o site da Nova Art Design e gostaria de conversar sobre um projeto de interiores.",
);
---

<section id="inicio" class="relative min-h-screen">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src={image}
      alt="Projeto de interiores"
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- Overlay -->
    <div
      class="absolute inset-0
         bg-gradient-to-r
         from-[#111]
         via-black/50
         to-transparent"
    >
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 min-h-screen flex items-center lg:pt-12">
    <div class="max-w-7xl mx-auto w-full px-6">
      <div class="max-w-[500px] text-white">
        <!-- Headline -->
        <div class="mb-6">
          <span class="uppercase tracking-[0.35em] text-xs text-[#d4b190]">
            Nova Art Design
          </span>

          <p class="mt-2 text-sm tracking-[0.3em] text-stone-300">INTERIORES</p>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-light leading-tight">
          Transformando ambientes em
          <span class="block italic text-[#d4b190]"> experiências únicas </span>
        </h1>

        <p class="mt-4 text-sm text-stone-300">
          Projetos residenciais e comerciais presencial em Florianópolis e região ou online.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href={`https://wa.me/5548984043490?text=${whatsappMessage}`}
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-[#d4b190] text-stone-900 rounded-md font-medium hover:opacity-90 transition"
          >
            Solicitar Orçamento
          </a>

          <a
            href="#projetos"
            class="px-8 py-4 border border-white rounded-md hover:bg-white/10 transition"
          >
            Ver Projetos
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <a
    href="#projetos"
    class="hidden md:block absolute z-30 bottom-8 left-1/2 -translate-x-1/2 text-white animate-bounce"
    aria-label="Ir para projetos"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
    </svg>
  </a>
</section>
