---
interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
}

const {
  title = "Nova Arte Design",
  subtitle = "Projetos de interiores que unem funcionalidade, conforto e beleza para transformar ambientes em experiências únicas.",
  image = "/images/hero/living-room.jpg"
} = Astro.props;

const whatsappMessage = encodeURIComponent(
  "Olá, Luciana! Visitei o site da Nova Arte Design e gostaria de conversar sobre um projeto de interiores."
);
---

<section class="relative min-h-[90vh] flex items-center">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src={image}
      alt="Projeto de interiores"
      class="w-full h-full object-cover"
    />

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-3xl text-white">
      <span
        class="inline-block mb-4 text-sm tracking-[0.25em] uppercase text-stone-200"
      >
        Design de Interiores
      </span>

      <h1
        class="text-5xl md:text-6xl lg:text-7xl font-light leading-tight"
      >
        {title}
      </h1>

      <p
        class="mt-6 text-lg md:text-xl text-stone-100 leading-relaxed max-w-2xl"
      >
        {subtitle}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="#projetos"
          class="inline-flex justify-center items-center px-8 py-4 bg-white text-stone-900 rounded-md font-medium hover:bg-stone-100 transition"
        >
          Ver Projetos
        </a>

        <a
          href={`https://wa.me/5548984043490?text=${whatsappMessage}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex justify-center items-center px-8 py-4 border border-white rounded-md text-white hover:bg-white/10 transition"
        >
          Solicitar Orçamento
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <a
    href="#projetos"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white animate-bounce cursor-pointer"
    aria-label="Ir para projetos"
    >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"
      />
    </svg>
  </a>
</section>