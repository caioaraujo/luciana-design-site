---
import ProjectCard from "./ProjectCard.astro";

interface Project {
  title: string;
  category: string;
  image: string;
  href: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section id="projetos" class="py-24 bg-stone-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-12">
      <span class="uppercase tracking-[0.3em] text-sm text-stone-500">
        Portfólio
      </span>

      <h2 class="mt-3 text-4xl md:text-5xl font-light text-stone-900">
        Projetos em Destaque
      </h2>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <ProjectCard
          title={project.title}
          category={project.category}
          image={project.image}
          href={project.href}
        />
      ))}
    </div>
  </div>
</section>