---
import "../styles/global.css";

import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>Nova Art Design</title>
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "InteriorDesigner",
				name: "Nova Art Design",
				url: "https://novaartdesign.com.br",
				telephone: "+5548984043490",
				image: "https://novaartdesign.com.br/images/logo/logo.jpg",
				description:
					"Projetos de interiores, móveis planejados e design de ambientes.",
				address: {
					"@type": "PostalAddress",
					addressLocality: "São José",
					addressRegion: "SC",
					addressCountry: "BR",
				},
			})}
		/>
	</head>
	<body>
		<slot />
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
